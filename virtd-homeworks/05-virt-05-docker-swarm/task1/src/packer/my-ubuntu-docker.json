{
  "builders": [
    {
      "type": "yandex",
      "token": "{{user `TOKEN`}}",
      "folder_id": "{{user `FOLDER_ID`}}",
      "zone": "{{user `DEFAULT_ZONE`}}",
      "image_name": "{{user `IMAGE_NAME`}}",
      "image_description": "my custom ubuntu with docker",
      "source_image_family": "{{user `IMAGE_FAMILY`}}",
      "subnet_id": "{{user `SUBNET_ID`}}",
      "use_ipv4_nat": true,
      "disk_type": "{{user `DISK_TYPE`}}",
      "ssh_username": "ubuntu"
    }
  ],
  "provisioners": [
    {
      "type": "file",
      "source": "../scripts/setup-docker.sh",
      "destination": "/tmp/setup-docker.sh"
    },
    {
      "type": "shell",
      "inline": [
        "chmod +x /tmp/setup-docker.sh",
        "/tmp/setup-docker.sh"
      ]
    }
  ]
}