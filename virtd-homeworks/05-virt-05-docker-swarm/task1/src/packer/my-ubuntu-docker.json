{
  "builders": [
    {
      "type": "yandex",
      "token": "{{ TOKEN }}",
      "folder_id": "{{ FOLDER_ID }}",
      "zone": "{{ DEFAULT_ZONE }}",
      "image_name": "ubuntu-22-04-lts-docker",
      "image_description": "my custom ubuntu with docker",
      "source_image_family": "ubuntu-22-04-lts",
      "subnet_id": "{{ SUBNET_ID }}",
      "use_ipv4_nat": true,
      "disk_type": "{{ DISK_TYPE }}",
      "ssh_username": "ubuntu"
    }
  ],
  "provisioners": [
    {
      "type": "file",
      "source": "../scripts/setup-docker.sh",
      "destination": "/tmp/setup-docker.sh"
    },
    {
      "type": "shell",
      "inline": [
        "chmod +x /tmp/setup-docker.sh",
        "/tmp/setup-docker.sh"
      ]
    }
  ]
}